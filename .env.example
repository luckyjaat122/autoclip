# ===================== AutoClip AI — Environment =====================
# Copy to .env.local and fill in. NEVER commit .env.local (it's gitignored).

# ---- Auth / Admin ----
AUTH_SECRET=change-me-to-a-long-random-string
# Comma-separated emails auto-promoted to admin (admins get free unlimited access).
ADMIN_EMAILS=you@example.com
# Public base URL of the deployed app — used for OAuth redirects.
# Local: leave empty (uses the browser origin). Prod: set to your domain.
NEXT_PUBLIC_APP_URL=https://autoclip-production-63f9.up.railway.app

# ---- Supabase (auth + Postgres + storage) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=clips
# Optional: Postgres URI (Settings -> Database) to run migrations from CLI.
SUPABASE_DB_URL=

# ---- File storage provider: supabase | firebase | r2 | local ----
STORAGE_PROVIDER=supabase

# ---- AI providers ----
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=

# ---- Razorpay (subscriptions) ----
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Pipeline tuning ----
WHISPER_MODEL=./models/ggml-base.bin   # fallback STT only (Deepgram is primary)
MAX_CLIPS_PER_RUN=4
MAX_SOURCE_SECONDS=1200                 # reject videos longer than 20 min

# ---- Cloudflare R2 (only if STORAGE_PROVIDER=r2; needs @aws-sdk/client-s3) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ---- Firebase (only if STORAGE_PROVIDER=firebase) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
